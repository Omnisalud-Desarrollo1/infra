# ==========================================
# JWT — Identico en TODAS las apps
# ==========================================
JWT_SECRET_KEY=una-clave-secreta-muy-dificil-de-adivinar
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=7200
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=21600

# ==========================================
# MySQL (servidor compartido)
# ==========================================
MYSQL_HOST=192.168.2.187
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=omnisalud.desarrollo

# ==========================================
# Cookies SSO
# ==========================================
# Vacio = cookies scoped al host actual (ngrok / mismo dominio)
COOKIE_DOMAIN=
COOKIE_SECURE=false

# ==========================================
# URLs / CORS
# ==========================================
# Vacio = relative al mismo dominio (path-based routing)
FRONTEND_URL=
CORS_ORIGINS=http://localhost

# ==========================================
# Let's Encrypt (staging para pruebas)
# ==========================================
LETSENCRYPT_EMAIL=admin@omnisalud.co
LETSENCRYPT_CA=https://acme-staging-v02.api.letsencrypt.org/directory

# ==========================================
# App1 — Desarrollo_Asistencial
# ==========================================
APP1_SECRET_KEY=app1-secret-key-change-me

# ==========================================
# App2 — Desarrollo_Comercial
# ==========================================
APP2_SECRET_KEY=app2-secret-key-change-me
APP2_DB_NAME=comercialdb
# APP2_DB_USER=      (usa MYSQL_USER si no se define)
# APP2_DB_PASSWORD=  (usa MYSQL_PASSWORD si no se define)

# ==========================================
# App3 — Negociaciones Control de Costos
# ==========================================
APP3_SECRET_KEY=app3-secret-key-change-me

# ==========================================
# Otros
# ==========================================
APP_ENV=development
NGROK_AUTHTOKEN=
