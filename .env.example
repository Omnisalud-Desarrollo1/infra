# ============================================================
# .env.example — Variables de entorno para docker-compose
# ============================================================
# COPIAR a .env y editar antes de docker compose up
# ============================================================

# ==========================================
# JWT — Debe ser identico en TODAS las apps
# ==========================================
JWT_SECRET_KEY=generate-a-strong-random-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=7200
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=21600

# ==========================================
# MySQL (host compartido por todas las apps)
# ==========================================
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=

# ==========================================
# Cookies SSO
# ==========================================
# Vacio = cookies scoped al host actual (compatible con ngrok)
# Produccion mismo dominio = vacio
# Subdominios = .portalcorporativo.omnisalud.co
COOKIE_DOMAIN=
COOKIE_SECURE=false

# ==========================================
# URLs / CORS
# ==========================================
# Vacio = relativo al mismo dominio (recomendado para path-based routing)
FRONTEND_URL=
CORS_ORIGINS=http://localhost

# ==========================================
# Let's Encrypt
# ==========================================
# Staging (pruebas):
LETSENCRYPT_EMAIL=admin@omnisalud.co
LETSENCRYPT_CA=https://acme-staging-v02.api.letsencrypt.org/directory
# Produccion: dejar LETSENCRYPT_CA vacio o comentado

# ==========================================
# App1 — Desarrollo_Asistencial
# ==========================================
APP1_SECRET_KEY=change-me-app1

# ==========================================
# App2 — Desarrollo_Comercial
# ==========================================
APP2_SECRET_KEY=change-me-app2
APP2_DB_NAME=comercialDB
APP2_DB_USER=
APP2_DB_PASSWORD=

# ==========================================
# Otros
# ==========================================
APP_ENV=development
NGROK_AUTHTOKEN=
